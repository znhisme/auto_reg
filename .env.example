# =============================================================================
# Any Auto Register - 环境变量配置示例
# =============================================================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际需求修改配置值
# 3. 不要将 .env 文件提交到 Git
# =============================================================================

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# 开发模式：0=生产模式，1=开发模式 (自动重载)
APP_RELOAD=0

# Conda 环境名称
APP_CONDA_ENV=any-auto-register

# -----------------------------------------------------------------------------
# 验证码服务配置
# -----------------------------------------------------------------------------

# YesCaptcha (可选，使用本地 Solver 时可不填)
# 获取地址：https://yescaptcha.com
YESCAPTCHA_CLIENT_KEY=

# 本地 Solver 配置 (默认自动启动，无需修改)
LOCAL_SOLVER_URL=http://127.0.0.1:8889
SOLVER_BROWSER_TYPE=camoufox

# -----------------------------------------------------------------------------
# 代理配置 (可选)
# -----------------------------------------------------------------------------
# 格式：http://username:password@ip:port 或 socks5://ip:port
# 示例：http://user:pass@127.0.0.1:7890
PROXY_URL=

# -----------------------------------------------------------------------------
# 邮箱服务配置 (根据使用的服务填写)
# -----------------------------------------------------------------------------

# MoeMail (默认临时邮箱，自动注册)
MOEMAIL_API_KEY=

# SkyMail / CloudMail
# 获取地址：https://cloudmail.ai
SKYMAIL_API_KEY=
SKYMAIL_DOMAIN=

# TempMail.lol (无需配置)
# 文档：https://tempmail.lol

# LuckMail (Temporary email service)
# Documentation: https://mails.luckyous.com
LUCKMAIL_API_KEY=

# GPTMail
GPTMAIL_API_KEY=

# CF Worker (自建邮箱)
# 参考：https://github.com/dreamhunter2333/cloudflare_temp_email
CFWORKER_API_URL=
CFWORKER_DOMAIN=

# -----------------------------------------------------------------------------
# 外部系统集成 (可选)
# -----------------------------------------------------------------------------

# Codex Protocol API (CPA)
CPA_API_URL=
CPA_API_KEY=

# Sub2API
SUB2API_URL=
SUB2API_KEY=

# Grok2API
GROK2API_URL=
GROK2API_KEY=

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 最大并发注册任务数
MAX_CONCURRENT_TASKS=5

# 默认注册重试次数
DEFAULT_RETRY_TIMES=3
